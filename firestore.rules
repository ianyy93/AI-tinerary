rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if user has access to a specific trip document
    function hasTripAccess(tripData) {
      return isSignedIn() && (
        tripData.userId == request.auth.uid ||
        (tripData.get('collaboratorUids', []) != null && request.auth.uid in tripData.get('collaboratorUids', [])) ||
        (request.auth.token.email != null && tripData.get('collaboratorEmails', []) != null && request.auth.token.email in tripData.get('collaboratorEmails', []))
      );
    }

    // Helper to check if user has write access (owner or editor)
    function isTripOwnerOrEditor(tripData) {
      return isSignedIn() && (
        tripData.userId == request.auth.uid ||
        tripData.get('collaborators', {}).get(request.auth.uid, 'viewer') == 'owner' ||
        tripData.get('collaborators', {}).get(request.auth.uid, 'viewer') == 'editor' ||
        (request.auth.token.email != null && (
          tripData.get('collaborators', {}).get(request.auth.token.email, 'viewer') == 'owner' ||
          tripData.get('collaborators', {}).get(request.auth.token.email, 'viewer') == 'editor'
        ))
      );
    }

    match /trips/{tripId} {
      allow create: if isSignedIn();
      allow read: if hasTripAccess(resource.data);
      allow update: if isTripOwnerOrEditor(resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Flat Events Collection
      match /events/{eventId} {
        allow read: if hasTripAccess(get(/databases/$(database)/documents/trips/$(tripId)).data);
        allow write: if isTripOwnerOrEditor(get(/databases/$(database)/documents/trips/$(tripId)).data);
      }
    }
  }
}
